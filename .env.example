# Copy to .env and fill in. None are required for local dev (sane defaults apply).
DB_URL=sqlite:///data/marketplace.db
SESSION_SIGNING_KEY=change-me-to-a-long-random-string
INSTITUTION_DOMAIN=calebuniversity.edu.ng
MEDIA_ROOT=media

# SMTP is optional in dev. If unset, verification links are written to the
# console and shown on-screen so the flow can be exercised without a mail server.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@calebuniversity.edu.ng

# Base URL used to build the verification link in emails.
APP_BASE_URL=http://localhost:8501
